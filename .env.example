# ===========================================
# Docker Compose – copy to .env in project root
# Compose loads this; backend gets DB + URL, frontend build gets API URL + token.
# ===========================================

# Postgres (required for Docker). DB name and user can be set to your preference; backend uses the same values.
POSTGRES_USER=strapi
POSTGRES_PASSWORD=replace_me
POSTGRES_DB=strapi

# URL the browser uses to reach the backend (frontend is built with this as API URL)
PUBLIC_URL=http://localhost:1337

# Strapi API token for the frontend – not auto-generated; create in Strapi Admin (Settings → API Tokens), then add here and rebuild frontend.
VITE_STRAPI_API_TOKEN=

# Frontend options. Set to true or false (used when building frontend image).
VITE_ENABLE_SERVER_LOGS=false
VITE_SHOW_PRAYER_DAY_LABELS=false

# Strapi cron tasks (e.g. scheduled jobs). Set to true or false.
CRON_ENABLED=false

# Override storage for backend (default in Docker is local)
# STORAGE_PROVIDER=local
# STORAGE_PROVIDER=cloudinary
