# ===========================================
# Masjidly Backend - copy to .env and fill in
# ===========================================

# Server (PUBLIC_URL: use http://localhost:1337 for Docker offline)
HOST=0.0.0.0
PORT=1337
PUBLIC_URL=http://localhost:1337

# ----- Secrets (replace with your own; see DOCKER.md for generating values) -----
APP_KEYS=replace_with_comma_separated_keys
API_TOKEN_SALT=replace_me
ADMIN_JWT_SECRET=replace_me
TRANSFER_TOKEN_SALT=replace_me
JWT_SECRET=replace_me

# ----- Database -----
# For Docker: use DATABASE_HOST=postgres (compose overrides this when using env_file)
# For local dev: use DATABASE_HOST=127.0.0.1
DATABASE_CLIENT=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=replace_me
DATABASE_SSL=false
DATABASE_SCHEMA=public

# ----- Storage: local (offline) or cloudinary (online) -----
# local = files in ./public/uploads (Docker: persisted in volume backend_uploads)
# cloudinary = use CLOUDINARY_* below
STORAGE_PROVIDER=local

# Cloudinary (only used when STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Legacy names (also supported)
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# ----- Email (optional; leave empty if not using SendGrid) -----
SENDGRID_API_KEY=

# ----- Optional -----
CRON_ENABLED=false
WEBHOOKS_POPULATE_RELATIONS=false
