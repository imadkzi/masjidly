# ===========================================
# Masjidly Frontend – copy this to .env (not .env.frontend)
# Vite only loads files named .env, so the file Vite reads must be .env.
# ===========================================
# Backend URL the browser will call (e.g. http://localhost:1337 for Docker).
VITE_STRAPI_URL=http://localhost:1337

# Strapi API token – not auto-generated. Create in Strapi Admin (Settings → API Tokens), then paste here.
VITE_STRAPI_API_TOKEN=

# Set to true or false (Docker: set in root .env and rebuild frontend)
VITE_ENABLE_SERVER_LOGS=false
VITE_SHOW_PRAYER_DAY_LABELS=false
